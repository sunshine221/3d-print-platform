generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  standard
  print_service
  both
}

enum ProductStatus {
  draft
  published
  archived
}

enum SKUStatus {
  active
  inactive
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
  make_to_order
}

enum OrderStatus {
  pending_confirmation
  in_production
  shipped
  completed
  cancelled
}

enum InquiryStatus {
  pending_review
  quoted
  negotiating
  accepted
  rejected
  closed
}

enum UserStatus {
  active
  disabled
}

enum FileType {
  image
  model_3d
  model_upload
  other
}

enum SenderType {
  customer
  admin
}

enum OperatorType {
  customer
  admin
  system
}


model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  phone               String   @unique
  passwordHash        String   @map("password_hash")
  name                String?
  avatarUrl           String?  @map("avatar_url")
  defaultContactName  String?  @map("default_contact_name")
  defaultContactPhone String?  @map("default_contact_phone")
  defaultAddress      String?  @map("default_address") @db.Text
  status              UserStatus @default(active)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  refreshTokens       RefreshToken[]
  orders              Order[]
  inquiries           PrintServiceInquiry[]


  pageViews           PageView[]

  @@map("users")
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  roleId       String   @map("role_id")
  status       UserStatus @default(active)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role           Role            @relation(fields: [roleId], references: [id])
  refreshTokens  RefreshToken[]
  operationLogs  OperationLog[]

  @@map("admin_users")
}

model Role {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  permissions Json        @default("[]")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  adminUsers  AdminUser[]

  @@map("roles")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  adminUserId String?   @map("admin_user_id")
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User?      @relation(fields: [userId], references: [id])
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])

  @@map("refresh_tokens")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  icon        String?
  imageUrl    String?   @map("image_url")
  description String?   @db.Text
  parentId    String?   @map("parent_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isVisible   Boolean   @default(true) @map("is_visible")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent   Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]  @relation("CategoryTree")
  products ProductCategory[]

  @@index([parentId, sortOrder])
  @@map("categories")
}

model Product {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  subtitle        String?
  description     String?       @db.Text
  productType     ProductType   @default(standard) @map("product_type")
  materials       String[]
  techniques      String[]
  tolerance       String?
  specs           Json          @default("[]")
  thumbnailUrl    String?       @map("thumbnail_url")
  status          ProductStatus @default(draft)
  seoTitle        String?       @map("seo_title")
  seoDescription  String?       @map("seo_description") @db.Text
  seoKeywords     String?       @map("seo_keywords")
  viewCount       Int           @default(0) @map("view_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  categories  ProductCategory[]
  images      ProductImage[]
  model3d     Model3D?
  skus        SKU[]
  orderItems  OrderItem[]
  inquiries   PrintServiceInquiry[]

  @@index([status])
  @@index([productType])
  @@map("products")
}

model ProductCategory {
  productId  String @map("product_id")
  categoryId String @map("category_id")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model Model3D {
  id           String   @id @default(uuid())
  productId    String   @unique @map("product_id")
  fileUrl      String   @map("file_url")
  fileName     String?  @map("file_name")
  fileSize     BigInt?  @map("file_size")
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("models_3d")
}

model SKU {
  id           String      @id @default(uuid())
  productId    String      @map("product_id")
  skuCode      String      @unique @map("sku_code")
  specCombo    Json        @map("spec_combo")
  price        Decimal     @map("price")
  minOrderQty  Int         @default(1) @map("min_order_qty")
  stockStatus  StockStatus @default(make_to_order) @map("stock_status")
  leadTimeDays Int?        @map("lead_time_days")
  imageUrl     String?     @map("image_url")
  status       SKUStatus   @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId, status])
  @@map("skus")
}

model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique @map("order_no")
  userId          String      @map("user_id")
  totalPrice      Decimal     @map("total_price")
  discountAmount  Decimal     @default(0) @map("discount_amount")
  couponCode      String?     @map("coupon_code")
  note            String?     @db.Text
  status          OrderStatus @default(pending_confirmation)
  contactName     String?     @map("contact_name")
  contactPhone    String?     @map("contact_phone")
  shippingAddress String?     @map("shipping_address") @db.Text
  trackingNumber  String?     @map("tracking_number")
  trackingCompany String?     @map("tracking_company")
  sourceInquiryId String?     @unique @map("source_inquiry_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user           User                  @relation(fields: [userId], references: [id])
  sourceInquiry  PrintServiceInquiry?  @relation(fields: [sourceInquiryId], references: [id])
  items          OrderItem[]
  logs           OrderLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  skuId       String  @map("sku_id")
  skuCode     String  @map("sku_code")
  specCombo   Json    @map("spec_combo")
  unitPrice   Decimal @map("unit_price")
  quantity    Int
  subtotal    Decimal

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  sku     SKU     @relation(fields: [skuId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderLog {
  id           String       @id @default(uuid())
  orderId      String       @map("order_id")
  action       String
  fromStatus   String?      @map("from_status")
  toStatus     String?      @map("to_status")
  operatorType OperatorType @map("operator_type")
  operatorId   String?      @map("operator_id")
  detail       String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_logs")
}

model PrintServiceInquiry {
  id                    String        @id @default(uuid())
  inquiryNo             String        @unique @map("inquiry_no")
  userId                String        @map("user_id")
  productId             String?       @map("product_id")
  desiredMaterial       String?       @map("desired_material")
  desiredColor          String?       @map("desired_color")
  desiredQuantity       Int?          @map("desired_quantity")
  desiredSize           String?       @map("desired_size")
  desiredDeadline       DateTime?     @map("desired_deadline") @db.Date
  additionalNotes       String?       @map("additional_notes") @db.Text
  contactName           String?       @map("contact_name")
  contactPhone          String?       @map("contact_phone")
  status                InquiryStatus @default(pending_review)
  adminQuoteUnitPrice   Decimal?      @map("admin_quote_unit_price")
  adminQuoteQuantity    Int?          @map("admin_quote_quantity")
  adminQuoteTotalPrice  Decimal?      @map("admin_quote_total_price")
  adminQuoteNote        String?       @map("admin_quote_note") @db.Text
  adminQuoteDeliveryDays Int?         @map("admin_quote_delivery_days")
  adminQuoteAt          DateTime?     @map("admin_quote_at")
  convertedOrderId      String?       @map("converted_order_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id])
  product       Product?             @relation(fields: [productId], references: [id])
  files         InquiryFile[]
  messages      InquiryMessage[]
  logs          InquiryLog[]
  sourceOrders  Order[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("print_service_inquiries")
}

model InquiryFile {
  id        String   @id @default(uuid())
  inquiryId String   @map("inquiry_id")
  fileUrl   String   @map("file_url")
  fileName  String?  @map("file_name")
  fileSize  BigInt?  @map("file_size")
  fileType  String?  @map("file_type")
  createdAt DateTime @default(now()) @map("created_at")

  inquiry PrintServiceInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_files")
}

model InquiryMessage {
  id         String     @id @default(uuid())
  inquiryId  String     @map("inquiry_id")
  senderType SenderType @map("sender_type")
  senderId   String     @map("sender_id")
  content    String     @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")

  inquiry PrintServiceInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@map("inquiry_messages")
}

model InquiryLog {
  id           String       @id @default(uuid())
  inquiryId    String       @map("inquiry_id")
  action       String
  fromStatus   String?      @map("from_status")
  toStatus     String?      @map("to_status")
  operatorType OperatorType @map("operator_type")
  operatorId   String?      @map("operator_id")
  detail       String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  inquiry PrintServiceInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@map("inquiry_logs")
}

model Banner {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  imageUrl  String   @map("image_url")
  linkUrl   String?  @map("link_url")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("banners")
}

model Page {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  content         String?  @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description") @db.Text
  isSystem        Boolean  @default(false) @map("is_system")
  status          String   @default("published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model MediaLibrary {
  id        String   @id @default(uuid())
  folderId  String?  @map("folder_id")
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  BigInt?  @map("file_size")
  fileType  FileType @map("file_type")
  mimeType  String?  @map("mime_type")
  width     Int?
  height    Int?
  isFolder  Boolean  @default(false) @map("is_folder")
  createdAt DateTime @default(now()) @map("created_at")

  parent   MediaLibrary?   @relation("MediaTree", fields: [folderId], references: [id])
  children MediaLibrary[]  @relation("MediaTree")

  @@index([folderId])
  @@map("media_library")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String?  @db.Text
  groupName String   @map("group_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([groupName])
  @@map("system_config")
}

model OperationLog {
  id          String   @id @default(uuid())
  adminUserId String?  @map("admin_user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  detail      Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("operation_logs")
}

model PageView {
  id        String   @id @default(uuid())
  pagePath  String   @map("page_path")
  visitorId String?  @map("visitor_id")
  userId    String?  @map("user_id")
  referrer  String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([pagePath, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("page_views")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  reply     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([isRead, createdAt(sort: Desc)])
  @@map("contact_messages")
}
